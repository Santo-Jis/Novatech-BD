{
  "name": "novatechbd-backend",
  "version": "1.0.0",
  "description": "NovaTechBD Management System - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:unit": "jest --coverage --testPathIgnorePatterns=integration",
    "test:integration": "jest --coverage --testPathPattern=integration",
    "test:order": "jest --coverage --testPathPattern=order.controller",
    "test:sales": "jest --coverage --testPathPattern=sales.controller",
    "test:settlement": "jest --coverage --testPathPattern=settlement.controller",
    "test:watch": "jest --watch",
    "test:customer": "jest --testPathPattern=customer.controller",
    "test:customer:int": "jest --testPathPattern=customer.integration",
    "test:customer:load": "node customer.load-test.js",
    "test:salary": "jest --testPathPattern=salary.controller",
    "test:salary:int": "jest --testPathPattern=salary.integration",
    "test:attendance": "jest --testPathPattern=attendance.controller",
    "test:attendance:int": "jest --testPathPattern=attendance.integration",
    "test:load": "node load-test.js",
    "test:load:priority": "node load-test-priority.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "pdfkit": "^0.14.0",
    "exceljs": "^4.4.0",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "firebase-admin": "^12.0.0",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
