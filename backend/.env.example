# ============================================================
# NovaTechBD Management System — Environment Variables
# এই ফাইলটি template। আসল .env ফাইলে আসল মান বসান।
# .env ফাইল কখনো GitHub-এ push করবেন না!
# cp .env.example .env
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Supabase PostgreSQL) ──────────────────────────
DB_HOST=your_supabase_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSL=true

# ─── JWT Secrets ─────────────────────────────────────────────
# generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES=7d

# ✅ Customer portal-এর জন্য আলাদা secret (employee token থেকে আলাদা রাখা বাধ্যতামূলক)
JWT_PORTAL_SECRET=your_portal_secret_key_min_64_chars

# ─── AES-256 Encryption (SMS API key এনক্রিপশনের জন্য) ──────
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key

# ─── Claude AI ───────────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key

# ─── SMS Gateway ─────────────────────────────────────────────
SMS_API_KEY=your_sms_api_key
SMS_DEVICE_ID=your_device_id
SMS_SENDER_ID=NovaTechBD

# ─── Email / Brevo SMTP ──────────────────────────────────────
# Render SMTP block করে — Brevo ব্যবহার করা হচ্ছে (smtp-relay.brevo.com)
EMAIL_ENABLED=true
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_brevo_login@email.com
EMAIL_PASS=your_brevo_smtp_key
EMAIL_FROM=NovaTech BD <noreply@yourdomain.com>

# ─── File Upload ─────────────────────────────────────────────
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# ─── Cloudinary (Image Upload) ───────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─── Firebase (Push Notification / Realtime DB) ──────────────
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
# Firebase Admin SDK service account JSON (একলাইনে stringify করা)
# node -e "console.log(JSON.stringify(require('./serviceAccount.json')))"
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Google ──────────────────────────────────────────────────
GOOGLE_MAPS_KEY=your_google_maps_api_key
GOOGLE_DRIVE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec

# ─── Frontend URL (CORS) ─────────────────────────────────────
# Production-এ Vercel URL দিন। একাধিক হলে comma দিয়ে আলাদা করুন।
# FRONTEND_URL=https://novatech-bd.vercel.app,https://novatech-bd-git-main.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── Render Keep-Alive ───────────────────────────────────────
# Render dashboard থেকে service URL কপি করো (free tier ঘুম থেকে জাগাতে)
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# ============================================================
# Frontend — Vite (frontend/.env ফাইলে রাখো)
# ============================================================
# VITE_API_URL=https://your-app-name.onrender.com/api
# VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# VITE_FIREBASE_API_KEY=your-firebase-api-key
# VITE_FIREBASE_APP_ID=1:123456:web:abcdef
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_VAPID_KEY=your-vapid-key
