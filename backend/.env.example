# ============================================================
# NovaTechBD Management System - Environment Variables
# এই ফাইলটি template। আসল .env ফাইলে আসল মান বসান।
# .env ফাইল কখনো GitHub-এ push করবেন না!
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database (Supabase PostgreSQL)
DB_HOST=your_supabase_host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSL=true

# JWT Tokens
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AES-256 Encryption (API key এনক্রিপশনের জন্য)
ENCRYPTION_KEY=your_64_char_hex_encryption_key

# Claude AI
CLAUDE_API_KEY=your_claude_api_key

# SMS Gateway (SSL Wireless)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=NovaTechBD

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=NovaTech BD <your_email@gmail.com>

# File Upload
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
