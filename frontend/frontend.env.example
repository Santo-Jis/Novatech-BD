# ============================================================
# NovaTechBD — Frontend Environment Variables (Vite)
# এই ফাইলটি template। আসল মান দিয়ে frontend/.env তৈরি করুন:
#   cp frontend/.env.example frontend/.env
# frontend/.env কখনো GitHub-এ push করবেন না!
# ============================================================

# ─── Backend API ─────────────────────────────────────────────
VITE_API_URL=https://your-app-name.onrender.com/api

# ─── Google OAuth ────────────────────────────────────────────
# ⚠️  backend/.env-এর GOOGLE_CLIENT_ID-এর সাথে হুবহু একই মান দিন।
#     আলাদা Client ID দিলে backend-এর aud check fail করবে।
#     Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Firebase (Push Notification) ────────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web app → SDK config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_APP_ID=1:123456:web:abcdef
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase Cloud Messaging VAPID key
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-key
